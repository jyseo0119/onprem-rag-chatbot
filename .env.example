# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# --- LLM provider selection ---------------------------------
# Which LLM backend the RAG chain uses. This is the single switch
# for the hybrid demo/on-prem story.
#   openai | gemini | vllm
LLM_PROVIDER=openai

# --- API providers (default demo path) ----------------------
# Only the key for the selected LLM_PROVIDER is required.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- On-prem path (vLLM + Qwen2.5) --------------------------
# vLLM exposes an OpenAI-compatible API, so we reuse the same client.
# See docs/on-prem-switch.md.
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_API_KEY=EMPTY

# --- Embeddings (BGE-m3, runs locally in demo and on-prem) --
EMBEDDING_MODEL=BAAI/bge-m3
# cpu | cuda
EMBEDDING_DEVICE=cpu

# --- Vector DB (Qdrant, local docker) -----------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=onprem_docs

# --- Retrieval tuning ---------------------------------------
RETRIEVAL_TOP_K=5
# Cosine similarity floor. Chunks below this are dropped to
# reduce hallucination on out-of-domain questions.
RETRIEVAL_SCORE_THRESHOLD=0.4

# --- Chunking -----------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- OCR (scanned PDFs, optional) ---------------------------
# Off by default. Scanned/image-only PDFs are otherwise skipped
# (never indexed as blank pages). To OCR them, install the extra
# (`uv sync --extra ocr`, pulls PaddleOCR + PyMuPDF) and set:
ENABLE_OCR=false
# PaddleOCR language pack (en | korean | ch | ...).
OCR_LANG=en
